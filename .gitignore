# --- Original game files & anything derived from them (NEVER commit) ---
*.dat
*.DAT
*.exe
*.EXE
*.com
*.COM
# Extracted/original-derived assets — regenerate locally with tools/extract_dat
/assets/sprites/
/assets/backgrounds/
/assets/palettes/
/assets/text/
# Keep the asset folders in git even when empty
!/assets/sprites/.gitkeep
!/assets/backgrounds/.gitkeep
!/assets/palettes/.gitkeep
!/assets/text/.gitkeep
# NOTE: /assets/backgrounds_hd/ is OWNED, newly-authored art (M4 swap) — it IS
# committed (not ignored) so the game ships modern backgrounds with no originals.

# --- Godot ---
.godot/
/android/
export.cfg
*.translation
# Editor-generated import sidecars: backgrounds are loaded via Image.load() at
# runtime (no import pipeline), so the .import files are local-only churn.
*.import

# --- Python (extraction tool) ---
__pycache__/
*.pyc
.venv/
venv/

# --- OS / editor ---
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Platform export builds (shipped as release assets, not committed)
build/
