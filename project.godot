; Engine configuration file.
; Neuromancer (Godot 4 Remake)
;
; Generated/maintained by hand at this early stage. Open in Godot 4.x.

config_version=5

[application]

config/name="Neuromancer"
config/description="Open-source Godot 4 remake of Interplay's 1988 Neuromancer."
run/main_scene="res://scenes/Boot.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameState="*res://src/core/GameState.gd"
Assets="*res://src/core/Assets.gd"

[display]

window/size/viewport_width=320
window/size/viewport_height=200
window/size/window_width_override=1280
window/size/window_height_override=800
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[rendering]

renderer/rendering_method="gl_compatibility"
textures/canvas_textures/default_texture_filter=0
